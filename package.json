{
  "name": "arcane-gaunt",
  "version": "1.0.0",
  "private": true,
  "description": "ArcaneGaunt — a first-person wizard roguelike",
  "author": "ArcaneGaunt contributors",
  "homepage": "https://github.com/hearn1/arcane-gaunt",
  "license": "UNLICENSED",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack:win": "electron-builder --win dir",
    "dist:win": "electron-builder --win nsis",
    "dist:portable": "electron-builder --win portable",
    "steam:prep": "npm run pack:win",
    "serve": "python serve.py",
    "test": "node test/run.mjs",
    "test:smoke": "node test/run.mjs",
    "test:validate": "node test/run.mjs data-validate",
    "test:reward": "node test/run.mjs reward-generate-validate",
    "test:level": "node test/run.mjs level-composition-validate"
  },
  "build": {
    "appId": "com.arcanegaunt.game",
    "productName": "ArcaneGaunt",
    "asar": true,
    "asarUnpack": [
      "node_modules/steamworks.js/dist/**/*"
    ],
    "copyright": "Copyright © 2026 ArcaneGaunt contributors",
    "files": [
      "index.html",
      "src/**/*",
      "vendor/**/*",
      "assets/**/*",
      "electron/**/*",
      "CREDITS.md",
      "README.md",
      "PRIVACY_POLICY.md",
      "!PROJECT_OVERVIEW.md",
      "!GAME_DESIGN.md",
      "!TECHNICAL_ARCHITECTURE.md",
      "!IMPLEMENTATION_PLAN.md",
      "!UI_AND_SCENE_FLOW.md",
      "!ASSET_GUIDELINES.md",
      "!BALANCE_NOTES.md",
      "!INITIAL_SANDBOX_PROMPT.md",
      "!NEXT_SESSION_PROMPT.md",
      "!todofeature.md",
      "!RELEASE_CHECKLIST.md",
      "!feature_*.md",
      "!serve.py",
      "!UltimateMonsters/**"
    ],
    "directories": {
      "output": "dist"
    },
    "fileAssociations": [],
    "win": {
      "icon": "assets/icons/arcane.ico",
      "executableName": "ArcaneGaunt",
      "target": [
        "dir",
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ArcaneGaunt",
      "installerIcon": "assets/icons/arcane.ico",
      "uninstallerIcon": "assets/icons/arcane.ico"
    }
  },
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^26.10.0"
  },
  "dependencies": {
    "@sentry/browser": "^9.0.0",
    "steamworks.js": "^0.4.0"
  }
}
